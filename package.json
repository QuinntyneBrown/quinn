{
  "name": "quinn",
  "version": "0.1.0",
  "description": "Local LLM coding agent CLI — like Claude Code, but fully offline via Ollama",
  "type": "module",
  "bin": {
    "quinn": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["llm", "cli", "ollama", "coding-agent", "local", "offline"],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "glob": "^11.0.1",
    "marked": "^15.0.6",
    "marked-terminal": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "optionalDependencies": {
    "playwright": "^1.50.1"
  }
}
